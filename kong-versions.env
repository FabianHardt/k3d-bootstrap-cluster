# Single source of truth for Kong component versions.
# Sourced by every Kong install/upgrade point (root helpers.sh,
# examples/kong-gateway/helpers.sh, examples/kong-ai-gateway/setup.sh) which
# pass these to helm via --set / --version. The values.yaml files no longer
# pin versions, so this file is the only place to bump Kong.
#
# 3.14 is the LTS line (support until 2029). AI Gateway access_logs/OTel
# metrics require Kong >= 3.14.
KONG_GATEWAY_VERSION=3.14.0.8
KONG_KIC_VERSION=3.5.10
KONG_INGRESS_CHART_VERSION=0.24.0
